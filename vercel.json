{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/actualites",
      "destination": "/actualites/index",
      "permanent": false
    },
    {
      "source": "/formations",
      "destination": "/formations/index",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}